# =============================================================================
# SECRETS — NEVER COMMIT THESE
# =============================================================================
*.jks
*.keystore
**/key.properties
*.p12
*.mobileprovision
*-service-account.json
*_base64.txt

# =============================================================================
# FLUTTER / DART
# =============================================================================
# Build outputs
**/build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies

# Pub cache
.pub-cache/
.pub/

# Generated files (we don't use code generation, but just in case)
*.g.dart
*.freezed.dart

# Coverage
coverage/

# =============================================================================
# ANDROID
# =============================================================================
**/android/.gradle/
**/android/local.properties
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/gradle/
# Note: key.properties is already covered above

